{
  "name": "web",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build -verbose",
    "copy": "cp package.json dist/server && cp pnpm-lock.yaml dist/server && cp pnpm-workspace.yaml dist/server && cp .deploy/astro-nodejs-run.sh dist && cp .deploy/website-deploy.sh dist",
    "copy:win": "copy \"package.json\" \"dist/server\" && copy \"pnpm-lock.yaml\" \"dist/server\" && copy \"pnpm-workspace.yaml\" \"dist/server\" && copy \".deploy/astro-nodejs-run.sh\" \"dist\" && copy \".deploy/website-deploy.sh\" \"dist\"",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/node": "^9.5.5",
    "@astroscope/boot": "^0.3.4",
    "@nanostores/logger": "^1.1.0",
    "@nanostores/persistent": "^1.3.3",
    "astro": "^5.18.1",
    "better-sqlite3": "^12.8.0",
    "dexie": "^4.3.0",
    "drizzle-orm": "^0.45.1",
    "fuse.js": "^7.1.0",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "html-entities": "^2.6.0",
    "nanostores": "^1.2.0",
    "nodemailer": "^8.0.1",
    "sharp": "^0.34.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitest/browser": "^4.1.2",
    "daisyui": "^5.5.19",
    "find-duplicate-dependencies": "^3.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  },
  "description": "Altex website based on Astro Framework and NodeJS server adapter",
  "keywords": [
    "astro",
    "js",
    "typescript",
    "nodejs"
  ],
  "author": "Iurii Gerasimov",
  "license": "ISC"
}
