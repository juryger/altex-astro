---
interface Props {
  isDialog?: boolean;
}
const { isDialog = false } = Astro.props;
---

<alerts-container class:list={['toast', 'toast-top', 'toast-center', 'z-10', 'm-2', 'min-w-lg', {'top-10': isDialog }, {'top-20': !isDialog } ]} 
  data-is_dialog={isDialog}
>
</alerts-container>

<script>
  import { createAlertMarkup } from "@/web/src/core/utils/alerts-manager";
  import { $alerts } from "@/web/src/core/stores/alert-store";
  import { regexTrue } from "@/lib/domain";
  
  class AlertsContainer extends HTMLElement {
    private storeUnsubscribe?: () => void;
    private isDialog: boolean = false;
    
    constructor() {
      super();
    }

    connectedCallback() {
      this.isDialog = regexTrue.test(this.dataset.is_dialog ?? "false");

      this.storeUnsubscribe = $alerts.listen((value) => {
        value.forEach((x, index) => {
          if (this.isDialog === x.isDialog) {
            const key = "alert-".concat(index.toString());
            const divAlert = document.createElement("div");
            this.appendChild(divAlert);
            divAlert.outerHTML = createAlertMarkup(key, x.kind, x.message);
            setTimeout(() => {
              const alertEl = this.querySelector("#".concat(key));
              alertEl?.remove();
            }, 3000)
          }
        });
      });
    }

    disconnectedCallback() {
      this.storeUnsubscribe && this.storeUnsubscribe();
    }
  }

  customElements.define('alerts-container', AlertsContainer);
</script>